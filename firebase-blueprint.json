{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with roles.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff", "user"] },
        "createdAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["email", "name", "role", "createdAt"]
    },
    "Post": {
      "title": "Post",
      "description": "A blog post.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "createdAt": { "type": "string", "format": "timestamp" },
        "updatedAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["title", "content", "authorId", "authorName", "status", "createdAt", "updatedAt"]
    },
    "Lead": {
      "title": "Lead",
      "description": "Sales or marketing lead.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "message": { "type": "string" },
        "source": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "contacted", "qualified", "lost"] },
        "createdAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["name", "email", "phone", "message", "source", "status", "createdAt"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "Client testimonial.",
      "type": "object",
      "properties": {
        "clientName": { "type": "string" },
        "company": { "type": "string" },
        "content": { "type": "string" },
        "rating": { "type": "number" },
        "isApproved": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["clientName", "company", "content", "rating", "isApproved", "createdAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat session.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "staffId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "closed"] },
        "createdAt": { "type": "string", "format": "timestamp" },
        "updatedAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["userId", "staffId", "status", "createdAt", "updatedAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A single message in a chat.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["senderId", "senderName", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles stored by their UID."
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Blog posts."
    },
    "/leads/{leadId}": {
      "schema": { "$ref": "#/entities/Lead" },
      "description": "Marketing leads."
    },
    "/testimonials/{testimonialId}": {
      "schema": { "$ref": "#/entities/Testimonial" },
      "description": "Client testimonials."
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Chat sessions for client inquiries."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Chat messages within a chat session."
    }
  }
}
